Hint
You are given a network of n nodes, labeled from 1 to n. You are also given times, a list of travel times as directed edges times[i] = (ui, vi, wi), where ui is the source node, vi is the target node, and wi is the time it takes for a signal to travel from source to target.

We will send a signal from a given node k. Return the minimum time it takes for all the n nodes to receive the signal. If it is impossible for all the n nodes to receive the signal, return -1.

 

Example 1:


Input: times = [[2,1,1],[2,3,1],[3,4,1]], n = 4, k = 2
Output: 2
Example 2:

Input: times = [[1,2,1]], n = 2, k = 1
Output: 1
Example 3:

Input: times = [[1,2,1]], n = 2, k = 2
Output: -1
 

Constraints:

1 <= k <= n <= 100
1 <= times.length <= 6000
times[i].length == 3
1 <= ui, vi <= n
ui != vi
0 <= wi <= 100
All the pairs (ui, vi) are unique. (i.e., no multiple edges.)

//using proitriity queue: 
class Solution {
public:
    int networkDelayTime(vector<vector<int>>& times, int n, int k) {
        vector<vector<pair<int, int>>> graph(n+1);

        //build adjency list(graph)
        for(auto &edge : times){
            int u = edge[0];
            int v = edge[1];
            int w = edge[2];
            graph[u].push_back({v,w});
        }

        //distance array
        //dist[i] is shortest time to reach i from k
        //initialize all dist. with a large value
        const int INF = 1e9;
        vector<int> dist(n+1, INF);

        //dis to starting node k = 0
        dist[k] = 0;

        //min heap, entry: {time_so_far, node}
        priority_queue<
            pair<int, int>,
            vector<pair<int, int>>,
            greater<pair<int, int>>
        > pq;

        //start from node k at time 0
        pq.push({0, k});

        //dijkstra's algorithm
        while(!pq.empty()){
            //get node with smallest known time so far
            auto [time_so_far, node] = pq.top();
            pq.pop();

            //if this time is already worse thann the bbest known, skip
            if(time_so_far > dist[node]) continue;

            //relax all outgoing edges from this node
            for(auto &[next, w] : graph[node]){
                int new_time = time_so_far + w;

                //if we found a faster way to reach 'next'
                if(new_time < dist[next]){
                    dist[next] = new_time;          //update shortest time
                    pq.push({new_time, next});          //push into heap for further exploration
                }
            }
        }

        //compute answer
        int answer = 0;
        for(int node = 1; node<=n; ++node){
            //if node is unreachable, return -1
            if(dist[node] == INF) return -1;
            //track the max. time(when last node gets signal)
            answer = max(answer, dist[node]);
        }
        return answer;

    }
};



///considering array of visited nodes, eliminating extra check and revisiting of visited nodes:
class Solution {
public:
    int networkDelayTime(vector<vector<int>>& times, int n, int k) {
        vector<vector<pair<int, int>>> graph(n+1);

        //build adjency list(graph)
        for(auto &edge : times){
            int u = edge[0];
            int v = edge[1];
            int w = edge[2];
            graph[u].push_back({v,w});
        }

        //distance array
        //dist[i] is shortest time to reach i from k
        //initialize all dist. with a large value
        const int INF = 1e9;

        vector<int> dist(n+1, INF);
        vector<bool> visited(n+1, false);

        //dis to starting node k = 0
        dist[k] = 0;

        //min heap, entry: {time_so_far, node}
        priority_queue<
            pair<int, int>,
            vector<pair<int, int>>,
            greater<pair<int, int>>
        > pq;

        //start from node k at time 0
        pq.push({0, k});

        //dijkstra's algorithm
        while(!pq.empty()){
            //get node with smallest known time so far
            auto [d, u] = pq.top();
            pq.pop();

            //if this node already visited
            if(visited[u]) continue;
            visited[u] = true;

            //relax all outgoing edges from this node
            for(auto &[v, w] : graph[u]){
                if(!visited[v] && d + w < dist[v]){   //if not visited
                //if we found a faster way to reach 'next'
                    dist[v] = d + w;          //update shortest time
                    pq.push({dist[v], v});          //push into heap for further exploration
                }
            }
        }

        //compute answer
        int answer = 0;
        for(int node = 1; node<=n; ++node){
            //if node is unreachable, return -1
            if(dist[node] == INF) return -1;
            //track the max. time(when last node gets signal)
            answer = max(answer, dist[node]);
        }
        return answer;

    }
};
