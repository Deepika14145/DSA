//fails for this test case "abbac"
class Solution {
public:
    int longestBalanced(string s) {
        int singleCharMax = longestSingleChar(s);

        int twoCharMax = max({
            longestTwoChar(s, 'a', 'b'),
            longestTwoChar(s, 'b', 'c'),
            longestTwoChar(s, 'a', 'c')
        });

        int threeCharMax = longestThreeChar(s);

        return max({singleCharMax, twoCharMax, threeCharMax});
    }

private:
    // Case 1: only one distinct character
    int longestSingleChar(const string& s) {
        int bestLength = 0;
        for (int start = 0; start < s.size();) {
            int end = start;
            while (end < s.size() && s[end] == s[start]) end++;
            bestLength = max(bestLength, end - start);
            start = end;
        }
        return bestLength;
    }

    // Case 2: exactly two distinct characters
    int longestTwoChar(const string& s, char ch1, char ch2) {
        int bestLength = 0;
        int n = s.size();
        int index = 0;

        while (index < n) {
            while (index < n && s[index] != ch1 && s[index] != ch2)
                index++;

            unordered_map<int, int> firstSeen;
            firstSeen[0] = index - 1;

            int balance = 0;
            while (index < n && (s[index] == ch1 || s[index] == ch2)) {
                balance += (s[index] == ch1 ? 1 : -1);

                if (firstSeen.count(balance))
                    bestLength = max(bestLength, index - firstSeen[balance]);
                else
                    firstSeen[balance] = index;

                index++;
            }
        }
        return bestLength;
    }

    // Helper to encode two integers into one key
    long long encodeKey(int d1, int d2) {
        return ((long long)(d1 + 100000) << 20) | (d2 + 100000);
    }

    // Case 3: all three characters
    int longestThreeChar(const string& s) {
        unordered_map<long long, int> firstSeen;
        firstSeen[encodeKey(0, 0)] = -1;

        int count[3] = {0, 0, 0};
        int bestLength = 0;

        for (int i = 0; i < s.size(); i++) {
            count[s[i] - 'a']++;

            int diffAB = count[0] - count[1];
            int diffBC = count[1] - count[2];

            long long state = encodeKey(diffAB, diffBC);

            if (firstSeen.count(state))
                bestLength = max(bestLength, i - firstSeen[state]);
            else
                firstSeen[state] = i;
        }
        return bestLength;
    }
};
