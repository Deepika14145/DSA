class Solution {
public: 
vector<vector<int>> minimumAbsDifference(vector<int>& arr) {
    sort(arr.begin(), arr.end());

    vector<vector<int>> res;
    int minDiff = INT_MAX;

    for (int i = 1; i < (int)arr.size(); i++) {
        int diff = arr[i] - arr[i - 1];

        if (diff <= minDiff) {
            if (diff < minDiff) {
                res.clear();
                minDiff = diff;
            }
            res.push_back({arr[i - 1], arr[i]});
        }
    }
    return res;
}
};
