class Solution {
public:
    int jobScheduling(vector<int>& start, vector<int>& end, vector<int>& profit) {
        int n = start.size();
        vector<vector<int>> jobs(n);

        for (int i = 0; i < n; i++)
            jobs[i] = {end[i], start[i], profit[i]};

        // Topological order of DAG
        sort(jobs.begin(), jobs.end());

        // dp[endTime] = max profit until that time
        map<int, int> dp;
        dp[0] = 0;

        for (auto &job : jobs) {
            int e = job[0];
            int s = job[1];
            int p = job[2];

            // Find best profit before start time
            auto it = dp.upper_bound(s);
            int bestBefore = prev(it)->second;

            int currProfit = bestBefore + p;

            // If this path is better, update DAG state
            if (currProfit > dp.rbegin()->second)
                dp[e] = currProfit;
        }

        return dp.rbegin()->second;
    }
};

