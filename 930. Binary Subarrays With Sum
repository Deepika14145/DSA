class Solution {
public:
    int numSubarraysWithSum(vector<int>& nums, int goal) {
        int n = nums.size(), ans = 0, pre = 0;
        unordered_map<int, int> mp;
        mp[0]++;
        for(int i=0; i<n; i++) {
            pre += nums[i];
            ans += mp[pre - goal];
            mp[pre]++;
        }
        return ans;
    }
};
0 <= goal <= nums.length
