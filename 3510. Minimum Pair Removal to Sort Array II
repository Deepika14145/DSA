class Solution {
public:
    int minimumPairRemoval(vector<int>& nums) {
        int n = nums.size();
        if (n <= 1) return 0;

        vector<long long> a(nums.begin(), nums.end());
        vector<int> prev(n), next(n);
        vector<char> alive(n, 1);

        int bad = 0;
        for (int i = 0; i < n; i++) {
            prev[i] = i - 1;
            next[i] = (i + 1 < n ? i + 1 : -1);
            if (i + 1 < n && a[i] > a[i + 1]) bad++;
        }

        priority_queue<pair<long long,int>,
            vector<pair<long long,int>>,
            greater<>> pq;
        pq = decltype(pq)(); // ensure clean allocation

        for (int i = 0; i + 1 < n; i++)
            pq.push({a[i] + a[i + 1], i});

        int ops = 0;

        while (bad > 0) {
            auto [sum, i] = pq.top();
            pq.pop();

            int j = next[i];
            if (j == -1 || !alive[i] || !alive[j]) continue;
            if (a[i] + a[j] != sum) continue;

            int pi = prev[i];
            int nj = next[j];

            // remove old violations
            if (pi != -1 && a[pi] > a[i]) bad--;
            if (a[i] > a[j]) bad--;
            if (nj != -1 && a[j] > a[nj]) bad--;

            // merge
            a[i] += a[j];
            alive[j] = 0;
            next[i] = nj;
            if (nj != -1) prev[nj] = i;

            // add new violations
            if (pi != -1 && a[pi] > a[i]) bad++;
            if (nj != -1 && a[i] > a[nj]) bad++;

            // push updated sums
            if (pi != -1)
                pq.push({a[pi] + a[i], pi});
            if (nj != -1)
                pq.push({a[i] + a[nj], i});

            ops++;
        }

        return ops;
    }
};
