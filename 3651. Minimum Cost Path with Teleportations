Hint
You are given a m x n 2D integer array grid and an integer k. You start at the top-left cell (0, 0) and your goal is to reach the bottom‐right cell (m - 1, n - 1).

There are two types of moves available:

Normal move: You can move right or down from your current cell (i, j), i.e. you can move to (i, j + 1) (right) or (i + 1, j) (down). The cost is the value of the destination cell.

Teleportation: You can teleport from any cell (i, j), to any cell (x, y) such that grid[x][y] <= grid[i][j]; the cost of this move is 0. You may teleport at most k times.

Return the minimum total cost to reach cell (m - 1, n - 1) from (0, 0).

 

Example 1:

Input: grid = [[1,3,3],[2,5,4],[4,3,5]], k = 2

Output: 7

Explanation:

Initially we are at (0, 0) and cost is 0.

Current Position	Move	New Position	Total Cost
(0, 0)	Move Down	(1, 0)	0 + 2 = 2
(1, 0)	Move Right	(1, 1)	2 + 5 = 7
(1, 1)	Teleport to (2, 2)	(2, 2)	7 + 0 = 7
The minimum cost to reach bottom-right cell is 7.

Example 2:

Input: grid = [[1,2],[2,3],[3,4]], k = 1

Output: 9

Explanation:

Initially we are at (0, 0) and cost is 0.

Current Position	Move	New Position	Total Cost
(0, 0)	Move Down	(1, 0)	0 + 2 = 2
(1, 0)	Move Right	(1, 1)	2 + 3 = 5
(1, 1)	Move Down	(2, 1)	5 + 4 = 9
The minimum cost to reach bottom-right cell is 9.

 

Constraints:

2 <= m, n <= 80
m == grid.length
n == grid[i].length
0 <= grid[i][j] <= 104
0 <= k <= 10


class Solution {
public:
    int minCost(vector<vector<int>>& grid, int k) {
        int m = grid.size();
        int n = grid[0].size();
        
        // Base case: If grid is 1x1, start is end, cost is 0.
        if (m == 1 && n == 1) return 0;

        // Priority Queue stores: {cost, row, col, teleports_used}
        // Min-heap ordered by cost
        priority_queue<tuple<int, int, int, int>, 
                       vector<tuple<int, int, int, int>>, 
                       greater<tuple<int, int, int, int>>> pq;

        // Dist array: dist[row][col][teleports_used]
        // Initialize with a large value (infinity)
        vector<vector<vector<int>>> dist(m, vector<vector<int>>(n, vector<int>(k + 1, 1e9)));

        // Initial state
        dist[0][0][0] = 0;
        pq.push({0, 0, 0, 0});

        // Optimization: Store all cells as {value, r, c} and sort them by value.
        // This allows us to efficiently find valid teleport destinations.
        vector<tuple<int, int, int>> sorted_cells;
        for (int r = 0; r < m; ++r) {
            for (int c = 0; c < n; ++c) {
                sorted_cells.emplace_back(grid[r][c], r, c);
            }
        }
        sort(sorted_cells.begin(), sorted_cells.end());

        // processed_idx[t] tracks the index in sorted_cells up to which we have 
        // already added destinations for the transition from t -> t+1.
        vector<int> processed_idx(k + 1, 0);

        // Direction arrays for Normal Moves (Right, Down)
        int dr[] = {0, 1};
        int dc[] = {1, 0};

        while (!pq.empty()) {
            auto [d, r, c, t] = pq.top();
            pq.pop();

            // If we found a shorter path to this state already, skip
            if (d > dist[r][c][t]) continue;

            // If we reached the target, return the cost
            if (r == m - 1 && c == n - 1) return d;

            // 1. Normal Moves (Right, Down)
            for (int i = 0; i < 2; ++i) {
                int nr = r + dr[i];
                int nc = c + dc[i];

                if (nr >= 0 && nr < m && nc >= 0 && nc < n) {
                    int new_cost = d + grid[nr][nc];
                    if (new_cost < dist[nr][nc][t]) {
                        dist[nr][nc][t] = new_cost;
                        pq.push({new_cost, nr, nc, t});
                    }
                }
            }

            // 2. Teleport Move (if teleports remaining)
            if (t < k) {
                int current_val = grid[r][c];
                
                // We can teleport to any cell (tr, tc) where grid[tr][tc] <= current_val.
                // We only need to process cells from sorted_cells that we haven't processed 
                // for this specific teleport count 't' yet.
                // Since Dijkstra processes nodes in increasing order of cost, we know that
                // if we processed a cell previously, we did so with a lower or equal cost.
                
                while (processed_idx[t] < sorted_cells.size()) {
                    auto [val, tr, tc] = sorted_cells[processed_idx[t]];
                    
                    if (val > current_val) break; // Optimization: Stop if values exceed current

                    // Teleport cost is 0, so cost remains 'd'. 
                    // State changes to t + 1.
                    if (d < dist[tr][tc][t + 1]) {
                        dist[tr][tc][t + 1] = d;
                        pq.push({d, tr, tc, t + 1});
                    }
                    
                    processed_idx[t]++;
                }
            }
        }

        return -1; // Should not reach here if a path exists
    }
};
