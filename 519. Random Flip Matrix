class Solution {
    int cols;
    int total;
    unordered_map<int, int> mp;
    mt19937 rng;

public:
    Solution(int m, int n) : cols(n), total(m * n), rng(random_device{}()) {
        mp.reserve(1024);
    }

    vector<int> flip() {
        uniform_int_distribution<int> dist(0, total - 1);
        int r = dist(rng);

        auto it = mp.find(r);
        int actual = (it == mp.end()) ? r : it->second;

        total--;

        auto itLast = mp.find(total);
        mp[r] = (itLast == mp.end()) ? total : itLast->second;

        return { actual / cols, actual % cols };
    }

    void reset() {
        mp.clear();
        // capacity remains reserved (faster reuse)
        // mp.reserve(1024);  // not needed again
        // restore total
        // rows not needed
    }
};
