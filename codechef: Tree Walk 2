#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

const int MOD = 998244353;

// Global variables to avoid passing them around in recursion
vector<vector<int>> adj;
vector<int> parent;
vector<int> sz;

// DFS to calculate subtree sizes and parent pointers (rooting at 1)
void dfs(int u, int p) {
    parent[u] = p;
    sz[u] = 1;
    for (int v : adj[u]) {
        if (v != p) {
            dfs(v, u);
            sz[u] += sz[v];
        }
    }
}

void solve() {
    int N;
    if (!(cin >> N)) return;

    // Reset/Initialize data structures
    adj.assign(N + 1, vector<int>());
    parent.assign(N + 1, 0);
    sz.assign(N + 1, 0);

    for (int i = 0; i < N - 1; ++i) {
        int u, v;
        cin >> u >> v;
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    // Edge case: N=1 is not possible per constraints (N>=2), 
    // but logic holds generally.

    // 1. Root the tree at vertex 1
    dfs(1, 0);

    // 2. Find the path from 1 to N
    // We trace back from N to 1 using parent array
    vector<int> path;
    int curr = N;
    while (curr != 0) {
        path.push_back(curr);
        curr = parent[curr];
    }
    // Reverse to get path 1 -> ... -> N
    reverse(path.begin(), path.end());

    // 3. Dynamic Programming along the path
    long long free_state = 1;    // DP[i][0]: Arriving at node i fresh
    long long blocked_state = 0; // DP[i][1]: Arriving at node i after a bounce from i-1

    // Iterate through path nodes from 1 up to parent of N
    // (We don't process N itself for detours as the walk ends immediately at N)
    for (size_t i = 0; i < path.size() - 1; ++i) {
        int u = path[i];
        int next_u = path[i+1];
        
        // Calculate number of valid side detours at u.
        // This is the size of the component at u excluding the branch towards N.
        // Since we rooted at 1, next_u is a child of u.
        long long ways_side = (sz[u] - sz[next_u]); 
        
        // Transitions
        // 1. From Free State:
        //    - Take a side detour (ways_side options) -> Next is Free
        //    - Bounce forward (1 option) -> Next is Blocked
        // 2. From Blocked State:
        //    - Must proceed directly (1 option) -> Next is Free
        
        long long next_free = (free_state * ways_side + blocked_state) % MOD;
        long long next_blocked = free_state; 
        
        free_state = next_free;
        blocked_state = next_blocked;
    }

    cout << free_state << "\n";
}

int main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int T;
    if (cin >> T) {
        while (T--) {
            solve();
        }
    }
    return 0;
}
